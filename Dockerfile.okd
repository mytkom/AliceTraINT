# RUN alien.py getCAcerts

USER root

# Go binary from builder
# chmod for regular users permissions for copied files
COPY --from=builder /app/AliceTraINT ./
# COPY --from=builder /app/.env ./

# Copy certificates
COPY --from=builder /app/usercert.pem ./usercert.pem
COPY --from=builder /app/userkey.pem ./userkey.pem
RUN chmod 0400 ./userkey.pem
ENV CCDB_SSL_CERT_PATH=./usercert.pem
ENV CCDB_SSL_KEY_PATH=./userkey.pem

# Frontend / static files
COPY --from=builder /app/web ./web
COPY --from=builder /app/static ./static

RUN mkdir -p . && \
    chgrp -R 0 . && \
    chmod -R g=u .

USER 1001

# Expose port
EXPOSE 8088

# ========================
# CMD
# ========================
CMD ["./AliceTraINT"]

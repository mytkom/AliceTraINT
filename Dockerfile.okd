FROM golang:1.22-alpine AS builder

# Dependencies for Go + Tailwind
RUN apk add --no-cache git build-base curl make

USER root
WORKDIR /app

# Copy Go modules
COPY go.mod go.sum ./
RUN go mod download

# Install Tailwind CLI
ENV TAILWIND_VERSION=v3.4.10
RUN curl -L "https://github.com/tailwindlabs/tailwindcss/releases/download/$TAILWIND_VERSION/tailwindcss-linux-x64" \
    -o /usr/local/bin/tailwindcss && \
    chmod +x /usr/local/bin/tailwindcss

# Copy all source
COPY . .

# Generate CSS
RUN make css


# Build the Go binary
RUN CGO_ENABLED=0 GOOS=linux go build -o AliceTraINT ./cmd/AliceTraINT

# Generate certificates
RUN apk add --no-cache openssl
RUN mkdir -p ~/.globus
RUN openssl pkcs12 -clcerts -nokeys -in ./gridCertificate.p12 -out ./usercert.pem -password pass:
RUN openssl pkcs12 -nocerts -nodes -in ./gridCertificate.p12 -out ./userkey.pem -password pass:
RUN chmod 0400 ./userkey.pem

# Use OpenShift-friendly base image to avoid read-only FS issues
FROM registry.access.redhat.com/ubi9 AS runtime

USER 1001

# RUN ls /etc/hosts -lhaF
WORKDIR /app
# RUN chmod -R 777 .

